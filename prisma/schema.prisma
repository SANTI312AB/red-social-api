}

model public_user {
  IDUSUARIO Int    @id @default(autoincrement())
  USERNAME  String @unique(map: "UNIQ_F6CE94983E6D9A3B") @db.VarChar(255)
  PASSWORD  String @db.VarChar(255)
}



model respuestas_post {
  ID_RESPUESTA     Int               @id @default(autoincrement())
  RESPUESTA        String            @db.VarChar(500)
  FECHA_RESPUESTA  DateTime          @db.DateTime(0)
  FECHA_EDICION    DateTime?         @db.DateTime(0)
  ID_COMENTARIO    Int
  IDLOGIN          Int
  likes_respuestas likes_respuesta[]
  login            login             @relation(fields: [IDLOGIN], references: [IDLOGIN], onDelete: NoAction, onUpdate: NoAction, map: "FK_6A769A6A43485913")
  comentarios_post comentarios_post  @relation(fields: [ID_COMENTARIO], references: [ID_COMENTARIO], onDelete: Cascade, onUpdate: NoAction, map: "FK_6A769A6A4ECBEAE7")

  @@index([IDLOGIN], map: "IDX_6A769A6A43485913")
  @@index([ID_COMENTARIO], map: "IDX_6A769A6A4ECBEAE7")
}

model likes_respuesta {
  ID_LIKE      Int             @id @default(autoincrement())
  IDLOGIN      Int
  ID_RESPUESTA Int
  FECHA        DateTime        @db.DateTime(0)
  respuesta    respuestas_post @relation(fields: [ID_RESPUESTA], references: [ID_RESPUESTA], onDelete: Cascade, onUpdate: NoAction, map: "FK_6A769A6A4ECBEA23")
  login        login           @relation(fields: [IDLOGIN], references: [IDLOGIN], onDelete: NoAction, onUpdate: NoAction, map: "FK_9A769A6A43485649")

  @@unique([IDLOGIN, ID_RESPUESTA], map: "IDLOGIN_ID_RESPUESTA")
  @@index([IDLOGIN], map: "FK_9A769A6A43485649")
  @@index([ID_RESPUESTA], map: "FK_6A769A6A4ECBEA23")
}





