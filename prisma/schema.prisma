}

model post {
  ID_POST             Int                 @id @default(autoincrement())
  DESCRIPCION         String              @db.VarChar(500)
  FECHA_CREACION      DateTime            @db.DateTime(0)
  FECHA_EDICION       DateTime?           @db.DateTime(0)
  SLUG_POST           String              @unique(map: "UNIQ_5A8A6C8D474C4444") @db.VarChar(500)
  IDLOGIN             Int
  comentarios_post    comentarios_post[]
  multimedia_post     multimedia_post[]
  login               login               @relation(fields: [IDLOGIN], references: [IDLOGIN], onDelete: NoAction, onUpdate: NoAction, map: "FK_5A8A6C8D43485913")
  post_etiquetas      post_etiquetas[]
  post_reaccion       post_reaccion[]
  posts_guardados     posts_guardados[]

  @@index([IDLOGIN], map: "IDX_5A8A6C8D43485913")
}

model post_reaccion {
  ID_POST_REACCION Int           @id @default(autoincrement())
  FECHA_REACCION   DateTime      @db.DateTime(0)
  IDLOGIN          Int
  ID_POST          Int
  IDTIPO_REACCION  Int
  tipo_reaccion    tipo_reaccion @relation(fields: [IDTIPO_REACCION], references: [IDTIPO_REACCION], onDelete: NoAction, onUpdate: NoAction, map: "FK_D6F4E170275AE3C3")
  post             post          @relation(fields: [ID_POST], references: [ID_POST], onDelete: Cascade, onUpdate: NoAction, map: "FK_D6F4E1702F2EA199")
  login            login         @relation(fields: [IDLOGIN], references: [IDLOGIN], onDelete: NoAction, onUpdate: NoAction, map: "FK_D6F4E17043485918")

  @@unique([IDLOGIN, ID_POST], map: "IDLOGIN_ID_POST")
  @@index([IDTIPO_REACCION], map: "IDX_D6F4E170275AE3C3")
  @@index([ID_POST], map: "FK_D6F4E1702F2EA199")
}

model etiquetas {
  ID_ETIQUETA     Int              @id @default(autoincrement())
  NOMBRE_ETIQUETA String           @unique @db.VarChar(100)
  post_etiquetas  post_etiquetas[]
}

model post_etiquetas {
  ID_POST     Int
  ID_ETIQUETA Int
  etiqueta    etiquetas @relation(fields: [ID_ETIQUETA], references: [ID_ETIQUETA], onDelete: Cascade)
  post        post      @relation(fields: [ID_POST], references: [ID_POST], onDelete: Cascade)

  @@id([ID_POST, ID_ETIQUETA])
  @@index([ID_ETIQUETA])
}

model posts_guardados {
  ID_GUARDADO Int      @id @default(autoincrement())
  FECHA       DateTime @db.DateTime(0)
  IDLOGIN     Int
  ID_POST     Int
  login       login    @relation(fields: [IDLOGIN], references: [IDLOGIN], onDelete: NoAction)
  post        post     @relation(fields: [ID_POST], references: [ID_POST], onDelete: Cascade)

  @@index([IDLOGIN])
  @@index([ID_POST])
}


model provincias {
  IDPROVINCIA      Int        @id @default(autoincrement())
  NOMBRE_PROVINCIA String     @db.VarChar(255)
  REGION_PROVINCIA String?    @db.VarChar(255)
